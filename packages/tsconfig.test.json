{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noImplicitAny": false,
    "resolveJsonModule": true
  },
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ],
  "include": [
    "**/tests",
    "**/src/*/rules/tools",
    "ruling/**/*",
    "**/src/*/rules/**/*.test.ts",
    "**/ruling/projects.json",
    "../typings/**/*.d.ts"
  ],
  "exclude": [
    "**/tests/**/fixtures*",
    "**/src/*/rules/**/*.fixture.*",
    "**/src/*/rules/**/fixtures"
  ]
}
